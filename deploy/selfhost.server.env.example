# Server deployment template for an IP-based Multica host.
# Copy to /opt/multica/.env on the server before the first deploy.

# Database
POSTGRES_DB=multica
POSTGRES_USER=multica
POSTGRES_PASSWORD=change-this-db-password
POSTGRES_PORT=5432

# Backend / frontend ports exposed on the server
PORT=8080
FRONTEND_PORT=3000

# Keep APP_ENV empty for raw HTTP/IP deployments.
# Setting APP_ENV=production or staging enables Secure cookies and requires HTTPS.
APP_ENV=

# Generate a strong secret before the first start.
JWT_SECRET=replace-with-openssl-rand-hex-32

# Public URLs for this server
FRONTEND_ORIGIN=http://195.209.212.86:3000
MULTICA_APP_URL=http://195.209.212.86:3000
MULTICA_SERVER_URL=ws://195.209.212.86:8080/ws
LOCAL_UPLOAD_BASE_URL=http://195.209.212.86:8080

# Allow the web app to talk to the API/WebSocket endpoint.
ALLOWED_ORIGINS=http://195.209.212.86:3000
CORS_ALLOWED_ORIGINS=http://195.209.212.86:3000

# Frontend container proxies requests to the backend container over Docker network.
REMOTE_API_URL=http://backend:8080
NEXT_PUBLIC_API_URL=http://195.209.212.86:8080
NEXT_PUBLIC_WS_URL=ws://195.209.212.86:8080/ws

# Optional auth providers
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@example.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://195.209.212.86:3000/auth/callback
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Optional file storage/CDN. Leave empty to use the local uploads volume.
S3_BUCKET=
S3_REGION=us-west-2
CLOUDFRONT_KEY_PAIR_ID=
CLOUDFRONT_PRIVATE_KEY=
CLOUDFRONT_DOMAIN=
COOKIE_DOMAIN=

# Local file storage inside the backend container
LOCAL_UPLOAD_DIR=./data/uploads
