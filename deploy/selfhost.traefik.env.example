# Public HTTPS hostname served by Traefik.
PUBLIC_DOMAIN=app.example.com

# Email used for Let's Encrypt expiry notices and ACME registration.
LETSENCRYPT_EMAIL=ops@example.com

# Production URLs for the backend container.
APP_ENV=production
FRONTEND_ORIGIN=https://app.example.com
MULTICA_APP_URL=https://app.example.com
MULTICA_SERVER_URL=wss://app.example.com/ws
LOCAL_UPLOAD_BASE_URL=https://app.example.com

# Same-origin browser access through Traefik.
ALLOWED_ORIGINS=https://app.example.com
CORS_ALLOWED_ORIGINS=https://app.example.com

# Optional: share auth cookies across subdomains.
# COOKIE_DOMAIN=.example.com
