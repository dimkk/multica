# Public hostname served by Caddy + Let's Encrypt.
PUBLIC_DOMAIN=app.example.com

# Email used for ACME registration and expiry notices.
LETSENCRYPT_EMAIL=ops@example.com

# Optional dedicated hostname for operator SSH-over-TLS via wstunnel.
SSH_TUNNEL_DOMAIN=ssh.app.example.com

# Run with Secure cookies once HTTPS is live.
APP_ENV=production

# Optional operator-only fallback code for self-hosted recovery.
# Requires a preceding /auth/send-code request for the same email.
MASTER_LOGIN_CODE=

# Public URLs exposed through Caddy.
FRONTEND_ORIGIN=https://app.example.com
MULTICA_APP_URL=https://app.example.com
MULTICA_SERVER_URL=wss://app.example.com/ws
LOCAL_UPLOAD_BASE_URL=https://app.example.com

# Same-origin browser access through Caddy.
ALLOWED_ORIGINS=https://app.example.com
CORS_ALLOWED_ORIGINS=https://app.example.com

# Leave NEXT_PUBLIC_API_URL and NEXT_PUBLIC_WS_URL empty so the frontend
# uses same-origin /api and dynamic ws/wss selection from the current host.
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_WS_URL=

# Optional: scope cookies to a shared parent domain, e.g. .example.com
COOKIE_DOMAIN=
